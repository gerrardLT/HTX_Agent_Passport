# =============================================================================
# HTX Agent Passport — 生产环境变量（.env.prod）
# 复制为 .env.prod 并填写真实值，然后：
#   docker compose --env-file .env.prod -f docker-compose.prod.yml up -d --build
# =============================================================================

# ---- PostgreSQL ----
POSTGRES_DB=htx_agent_passport
POSTGRES_USER=htx_agent
POSTGRES_PASSWORD=CHANGE_ME_STRONG_RANDOM_PASSWORD

# ---- 凭证保险库（AES-256-GCM 主密钥，64 hex 字符）----
# 生成：python -c "import secrets; print(secrets.token_hex(32))"
VAULT_MASTER_KEY=CHANGE_ME_64_HEX_CHARS

# ---- JWT 认证 ----
# 生成：python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_STRONG_RANDOM_JWT_SECRET

# ---- 演示模式 ----
DEMO_MODE=true
DEMO_REAL_TRADE=false
DEMO_DISABLE_EXECUTION=false

# ---- B.AI Planner（可选，留空走 mock）----
BAI_API_KEY=
BAI_API_URL=https://api.b.ai/v1
BAI_MODEL=deepseek-v4-flash

# ---- HTX 适配器 ----
HTX_API_URL=https://api.huobi.pro

# ---- 前端 ----
NEXT_PUBLIC_EXECUTION_MODE=SIMULATION

# ---- Nginx 端口 ----
HTTP_PORT=80
