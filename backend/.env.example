# ============================================================
# HTX Agent Passport — Environment Variables Template
# ============================================================
# Copy to `.env` and fill in the required values.
# Required fields are marked with [REQUIRED].
# ============================================================

# ---- 认证 / JWT [REQUIRED] ----
# HS256 签名密钥；至少 32 字符；生产环境必须替换为随机字符串
# 生成方式: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=replace_with_jwt_secret
JWT_ALGORITHM=HS256
JWT_EXPIRE_HOURS=24
DEMO_WALLET=0xA11CE00000000000000000000000000000000001

# ---- 数据库 ----
# PostgreSQL 连接串（Neon / Supabase / 本地 Docker）
DATABASE_URL=postgresql+psycopg://htx_agent:htx_agent_dev_password@localhost:5432/htx_agent_passport

# ---- 运行模式 ----
DEMO_MODE=true
DEMO_REAL_TRADE=false
DEMO_DISABLE_EXECUTION=false

# ---- 凭证保险库 [REQUIRED for credential encryption] ----
# AES-256-GCM 主密钥（64 hex chars）
# 生成方式: python -c "import secrets; print(secrets.token_hex(32))"
VAULT_MASTER_KEY=
VAULT_KEY_PROVIDER=local
# VAULT_KMS_KEY_ID=  # AWS KMS CMK ID/ARN (VAULT_KEY_PROVIDER=aws-kms)

# ---- 审计哈希链 ----
GENESIS_HASH=HTX_AGENT_PASSPORT_GENESIS_V1
AUDIT_STH_SIGNING_KEY=
AUDIT_STH_INTERVAL_SECONDS=300.0
AUDIT_STH_ENABLED=true
AUDIT_STH_ANCHOR_PATH=
AUDIT_STH_ANCHOR_BACKEND=jsonl
# AUDIT_STH_ANCHOR_S3_BUCKET=
# AUDIT_STH_ANCHOR_S3_RETENTION_YEARS=7
# AUDIT_STH_ANCHOR_S3_KEY_PREFIX=sth/
# AUDIT_STH_ANCHOR_S3_REGION=
# AUDIT_STH_ANCHOR_S3_ENDPOINT=

# ---- 审计签名算法 ----
# hmac-sha256（默认，向后兼容）/ ed25519（生产推荐）
AUDIT_STH_SIGNING_ALGO=hmac-sha256
# AUDIT_STH_ED25519_PRIVATE_KEY_PATH=
# AUDIT_STH_ED25519_PUBLIC_KEY_PATH=

# ---- 信息流追踪 ----
ENFORCE_MARKET_PROVENANCE=false

# ---- Cedar shadow evaluator ----
CEDAR_SHADOW_ENABLED=false

# ---- B.AI Planner 适配器 ----
BAI_API_KEY=
BAI_API_URL=https://api.b.ai/v1
BAI_MODEL=deepseek-v4-flash
BAI_TIMEOUT_SECONDS=30
BAI_MAX_RETRIES=2

# ---- HTX 适配器 ----
HTX_API_URL=https://api.huobi.pro

# ---- CORS 配置 [REQUIRED for production] ----
# 逗号分隔的允许源列表；生产必须配置具体域名
# 示例: https://app.example.com,https://admin.example.com
CORS_ORIGINS=["http://localhost:3000"]
