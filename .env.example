# =============================================================================
# HTX Agent Passport —— 环境变量样例
# 复制为 .env 后再填入真实值。.env 已在 .gitignore 中，不会被提交。
# 详见 requirements.md / design.md「凭证保险库」「执行网关」「审计哈希链」章节。
# =============================================================================

# -----------------------------------------------------------------------------
# 凭证保险库（Req 2 / 任务 4.1）
# -----------------------------------------------------------------------------
# AES-256-GCM 主密钥，必须为 32 字节 hex（64 个十六进制字符）。
# 生成示例：python -c "import secrets; print(secrets.token_hex(32))"
# 信封加密（envelope encryption）中作为 KEK（VAULT_KEY_PROVIDER=local 时）。
VAULT_MASTER_KEY=replace_with_64_hex_chars_for_aes_256_gcm_master_key_xxxxxxxxxxxxxxxx

# KEK provider：local（默认，从 VAULT_MASTER_KEY 派生，开发/演示用）
#               aws-kms（生产推荐，KEK 永不离开 KMS/HSM 边界，需配 VAULT_KMS_KEY_ID）
VAULT_KEY_PROVIDER=local
# AWS KMS CMK ID/ARN（仅 VAULT_KEY_PROVIDER=aws-kms 时必填）
VAULT_KMS_KEY_ID=

# -----------------------------------------------------------------------------
# 认证（Req 1 / 任务 3）
# -----------------------------------------------------------------------------
# JWT 签名密钥（HS256）。
JWT_SECRET=replace_with_strong_random_jwt_signing_secret

# -----------------------------------------------------------------------------
# 数据库（任务 2 / docker-compose）
# -----------------------------------------------------------------------------
# 默认与仓库根 docker-compose.yml 暴露的 PostgreSQL 一致。
DATABASE_URL=postgresql+psycopg://htx_agent:htx_agent_dev_password@localhost:5432/htx_agent_passport

# -----------------------------------------------------------------------------
# B.AI Planner 适配器（Req 5 / 任务 10）
# -----------------------------------------------------------------------------
BAI_API_KEY=replace_with_bai_api_key_or_leave_blank_to_use_mock_planner
BAI_API_URL=https://api.b.ai/v1
BAI_TIMEOUT_SECONDS=30
BAI_MAX_RETRIES=2

# -----------------------------------------------------------------------------
# HTX 适配器（Req 10 / 任务 12）
# -----------------------------------------------------------------------------
# Demo 默认走 mock，无需真实 HTX 凭证；填写后可启用 real_read / real_trade。
HTX_API_URL=https://api.huobi.pro

# -----------------------------------------------------------------------------
# 演示模式开关（Req 9 / Req 15 / Req 25）
# -----------------------------------------------------------------------------
# 是否允许真实交易（real_trade 模式必须为 true 才会执行下单）。
DEMO_REAL_TRADE=false
# 全局 kill switch：true 时 Policy Engine 对所有非只读操作返回 EXECUTION_DISABLED。
DEMO_DISABLE_EXECUTION=false
# 演示模式总开关：true 时启用种子数据 + mock 凭证 + 环境徽章 DEMO。
DEMO_MODE=true

# -----------------------------------------------------------------------------
# 审计哈希链（Req 11 / 任务 7）
# -----------------------------------------------------------------------------
# 审计链首事件的 previous_event_hash，必须是固定常量字符串。
GENESIS_HASH=HTX_AGENT_PASSPORT_GENESIS_V1

# -----------------------------------------------------------------------------
# CORS 与安全（Task 4 / 生产部署必填）
# -----------------------------------------------------------------------------
# CORS 允许的前端源列表（JSON 数组格式）。
# 开发默认 ["http://localhost:3000"]；生产必须配置具体域名。
CORS_ORIGINS=["http://localhost:3000"]

# -----------------------------------------------------------------------------
# 安全检查提示
# -----------------------------------------------------------------------------
# ⚠️ 生产部署前请确保：
#   1. JWT_SECRET 是 ≥32 字符的随机字符串
#   2. VAULT_MASTER_KEY 是 64 hex 字符的随机密鑰
#   3. CORS_ORIGINS 配置为具体域名，不使用通配符
#   4. DEMO_MODE=false 以启用 HSTS 安全响应头
#   5. DEMO_REAL_TRADE 仅在配置了真实 HTX API 凭证后启用

# -----------------------------------------------------------------------------
# 火山引擎 TTS 语音合成（产品演示视频旁白配音）
# -----------------------------------------------------------------------------
# 火山引擎 API Key（控制台 → API Key 管理 → 新建）
# 留空时演示页面降级到浏览器内置 Web Speech API
VOLCENGINE_TTS_API_KEY=
# 默认音色 ID（可在火山引擎控制台音色库查看完整列表）
VOLCENGINE_TTS_VOICE_ID=zh_female_vv_uranus_bigtts
